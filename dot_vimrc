" Checkout a git branch with fzf
command! -nargs=? -complete=custom,s:GitBranches Gitco
  \ if empty(<q-args>) |
  \   call fzf#run(fzf#wrap({
  \     'source': 'git branch --format="%(refname:short)"',
  \     'sink': {branch -> execute('Git checkout ' .. branch)},
  \     'options': '--prompt="Checkout> "',
  \   })) |
  \ else |
  \   execute('Git checkout ' .. <q-args>) |
  \ endif

def s:GitBranches(A: string, L: string, P: number): string
  return system('git branch --format="%(refname:short)"')
