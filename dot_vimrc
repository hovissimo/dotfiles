" {{{ Functions
" {{{2 CloseHiddenBuffers
function! CloseHiddenBuffers()
    " figure out which buffers are visible in any tab
    let visible = {}
    for t in range(1, tabpagenr('$'))
        for b in tabpagebuflist(t)
            let visible[b] = 1
        endfor
    endfor
    " close any buffer that's loaded and not visible
    for b in range(1, bufnr('$'))
        if bufloaded(b) && !has_key(visible, b)
            exe 'bd! ' . b
        endif
    endfor
endfun"
" }}}2
" {{{2 OpenClaudeTerminal
function! OpenClaudeTerminal()
    " Check if a buffer named 'claude' already exists
    let claude_bufnr = bufnr('claude')

    if claude_bufnr != -1
        " Buffer exists - check if it's still a terminal buffer
        if getbufvar(claude_bufnr, '&buftype') == 'terminal'
            " Buffer is a valid terminal - check if it's visible in any window
            let claude_winid = bufwinid(claude_bufnr)

            if claude_winid != -1
                " Buffer is visible - just switch to that window
                call win_gotoid(claude_winid)
            else
                " Buffer exists but not visible - open it in vertical split
                execute 'vertical sbuffer' claude_bufnr
            endif
        else
            " Buffer exists but is not a terminal - delete it and create new one
            execute 'bwipeout!' claude_bufnr
            vertical terminal ++close claude-vim
            file claude
        endif
    else
        " Buffer doesn't exist - create new terminal with claude
        vertical terminal ++close claude-vim

        " Rename the buffer to 'claude'
        file claude
    endif
endfunction
" }}}2
" {{{2 OpenTerminal
function! OpenTerminal()
    " Check if a buffer named 'terminal' already exists
    let terminal_bufnr = bufnr('terminal')

    if terminal_bufnr != -1
        " Buffer exists - check if it's still a terminal buffer
        if getbufvar(terminal_bufnr, '&buftype') == 'terminal'
            " Buffer is a valid terminal - check if it's visible in any window
            let terminal_winid = bufwinid(terminal_bufnr)

            if terminal_winid != -1
                " Buffer is visible - just switch to that window
                call win_gotoid(terminal_winid)
            else
                " Buffer exists but not visible - open it in horizontal split
                execute 'sbuffer' terminal_bufnr
            endif
        else
            " Buffer exists but is not a terminal - delete it and create new one
            execute 'bwipeout!' terminal_bufnr
            terminal ++close
            file terminal
        endif
    else
        " Buffer doesn't exist - create new terminal
        terminal ++close

        " Rename the buffer to 'terminal'
        file terminal
    endif
endfunction
